{
    "name": "neosapience/typecast-php",
    "description": "Official PHP SDK for Typecast Text-to-Speech API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Neosapience\\Typecast\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Neosapience\\Typecast\\Tests\\": "tests/"
        }
    }
}
