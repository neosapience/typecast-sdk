{
    "name": "neosapience/typecast-php",
    "description": "Official PHP SDK for Typecast Text-to-Speech API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Neosapience\\Typecast\\": "typecast-php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Neosapience\\Typecast\\Tests\\": "typecast-php/tests/"
        }
    },
    "support": {
        "source": "https://github.com/neosapience/typecast-sdk/tree/main/typecast-php"
    }
}
