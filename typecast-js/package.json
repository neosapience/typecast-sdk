{
  "name": "@neosapience/typecast-js",
  "version": "0.4.8",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage --exclude 'test/e2e/**'",
    "test:e2e": "vitest run test/e2e",
    "test:package": "bash scripts/test-package.sh",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && vitest run && npm run build",
    "link:dev": "npm link",
    "clean": "rm -rf lib",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "typecast",
    "tts",
    "text-to-speech",
    "ai",
    "voice",
    "speech-synthesis",
    "typescript",
    "nodejs",
    "javascript",
    "sdk"
  ],
  "author": "Neosapience <help@typecast.ai>",
  "license": "Apache-2.0",
  "description": "The official Node.js library for the Typecast API. Text-to-Speech with AI voices. TypeScript support included.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neosapience/typecast-sdk.git",
    "directory": "typecast-js"
  },
  "homepage": "https://typecast.ai",
  "bugs": {
    "url": "https://github.com/neosapience/typecast-sdk/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^3.2.6",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "prettier": "^3.2.5",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "brace-expansion@1": "1.1.16",
    "brace-expansion@2": "2.1.2",
    "brace-expansion@>=3 <5.0.7": "5.0.7",
    "js-yaml": "4.3.0",
    "esbuild": "^0.28.1"
  },
  "dependencies": {}
}
